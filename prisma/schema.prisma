// ─────────────────────────────────────────────
// Restaurant CRM — Prisma schema
// ─────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(STAFF)
  isActive      Boolean   @default(true)
  locale        String    @default("uk")

  accounts      Account[]
  sessions      Session[]
  reservations  Reservation[] @relation("CreatedByUser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  OWNER
  MANAGER
  STAFF
}

// ─────────────────────────────────────────────
// TABLES & FLOOR PLAN
// ─────────────────────────────────────────────

model Table {
  id           String    @id @default(cuid())
  name         String    @unique
  capacity     Int
  minCapacity  Int       @default(1)
  zone         TableZone @default(INDOOR)
  isActive     Boolean   @default(true)

  posX         Float     @default(0)
  posY         Float     @default(0)

  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tables")
}

enum TableZone {
  INDOOR
  OUTDOOR
  TERRACE
  PRIVATE
}

// ─────────────────────────────────────────────
// RESERVATIONS
// ─────────────────────────────────────────────

model Reservation {
  id          String            @id @default(cuid())

  guestName   String
  guestEmail  String
  guestPhone  String
  guestCount  Int
  comment     String?           @db.Text
  locale      String            @default("de")

  date        DateTime          @db.Date
  startTime   DateTime
  endTime     DateTime

  status      ReservationStatus @default(CONFIRMED)
  source      ReservationSource @default(WEBSITE)

  tableId     String
  table       Table    @relation(fields: [tableId], references: [id])

  createdById String?
  createdBy   User?    @relation("CreatedByUser", fields: [createdById], references: [id])

  confirmationSentAt DateTime?
  reminderSentAt     DateTime?

  internalNote String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([tableId, startTime, endTime])
  @@index([status])
  @@map("reservations")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReservationSource {
  WEBSITE
  PHONE
  WALKIN
  ADMIN
}

// ─────────────────────────────────────────────
// WORKING HOURS
// ─────────────────────────────────────────────

model WorkingHours {
  id              String  @id @default(cuid())
  dayOfWeek       Int     @unique
  isOpen          Boolean @default(true)
  openTime        String
  closeTime       String
  lastBookingTime String

  @@map("working_hours")
}

// ─────────────────────────────────────────────
// SETTINGS
// ─────────────────────────────────────────────

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("settings")
}

// ─────────────────────────────────────────────
// MENU
// ─────────────────────────────────────────────

model MenuCategory {
  id        String     @id @default(cuid())
  nameDE    String
  nameEN    String?
  nameUK    String?
  slug      String     @unique
  position  Int        @default(0)
  isVisible Boolean    @default(true)

  items     MenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("menu_categories")
}

model MenuItem {
  id            String       @id @default(cuid())
  categoryId    String
  category      MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  nameDE        String
  nameEN        String?
  nameUK        String?
  descriptionDE String?      @db.Text
  descriptionEN String?      @db.Text
  descriptionUK String?      @db.Text

  price         Decimal?     @db.Decimal(8, 2)

  imageUrl      String?

  allergens     Allergen[]   @default([])

  isVegetarian  Boolean      @default(false)
  isVegan       Boolean      @default(false)

  spicyLevel    Int          @default(0)

  isAvailable   Boolean      @default(true)
  position      Int          @default(0)

  variants      MenuItemVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, position])
  @@map("menu_items")
}

model MenuItemVariant {
  id        String   @id @default(cuid())
  itemId    String
  item      MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  labelDE   String
  labelEN   String?
  labelUK   String?

  price     Decimal  @db.Decimal(8, 2)
  position  Int      @default(0)

  @@index([itemId, position])
  @@map("menu_item_variants")
}

enum Allergen {
  GLUTEN
  CRUSTACEANS
  EGGS
  FISH
  PEANUTS
  SOYBEANS
  MILK
  NUTS
  CELERY
  MUSTARD
  SESAME
  SULPHITES
  LUPIN
  MOLLUSCS
}

// ─────────────────────────────────────────────
// PROMOTIONS / АКЦИИ
// ─────────────────────────────────────────────

model Promotion {
  id            String   @id @default(cuid())
  titleDE       String
  titleEN       String?
  titleUK       String?
  descriptionDE String?  @db.Text
  descriptionEN String?  @db.Text
  descriptionUK String?  @db.Text

  slug          String   @unique
  imageUrl      String?

  startDate     DateTime @db.Date
  endDate       DateTime @db.Date

  // Опционально: дни недели когда действует (например бизнес-ланч Mon-Fri)
  // Хранится как массив 0-6 (0 = воскресенье)
  // Пустой массив = действует все дни
  daysOfWeek    Int[]    @default([])

  // Опционально: часы действия (например 12:00-15:00)
  startTime     String?  // "12:00"
  endTime       String?  // "15:00"

  // Архивированные акции остаются в БД, но не показываются на сайте
  isActive      Boolean  @default(true)
  isArchived    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate, endDate])
  @@index([isActive, isArchived])
  @@map("promotions")
}

// ─────────────────────────────────────────────
// GALLERY
// ─────────────────────────────────────────────

// Категории галереи — теперь редактируемые через CRM
model GalleryCategory {
  id        String         @id @default(cuid())
  nameDE    String
  nameEN    String?
  nameUK    String?
  slug      String         @unique
  position  Int            @default(0)
  isVisible Boolean        @default(true)

  images    GalleryImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gallery_categories")
}

model GalleryImage {
  id         String          @id @default(cuid())
  url        String
  altDE      String?
  altEN      String?
  altUK      String?

  categoryId String
  category   GalleryCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  // Featured-фото показываются на главной странице (hero/карусель)
  isFeatured Boolean         @default(false)

  position   Int             @default(0)
  isVisible  Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, position])
  @@index([isFeatured])
  @@map("gallery_images")
}

// ─────────────────────────────────────────────
// CONTACTS
// ─────────────────────────────────────────────

model Contact {
  id    String  @id @default(cuid())
  key   String  @unique
  value String  @db.Text
  label String?

  updatedAt DateTime @updatedAt

  @@map("contacts")
}
